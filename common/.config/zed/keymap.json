[
  {
    "bindings": {
      "cmd-,": "editor::ToggleInlayHints",
      "cmd-+": "zed::IncreaseBufferFontSize",
      "cmd-_": "zed::DecreaseBufferFontSize",
      "cmd-e": "project_panel::ToggleFocus",
      "cmd-h": "editor::ViewBookmarks",
      "cmd-j": "terminal_panel::ToggleFocus",
      "cmd-shift-o": "projects::OpenRecent",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd--": "pane::GoBack",
      "cmd-=": "pane::GoForward",
      "ctrl-h": "editor::ToggleBookmark",
      "cmd-k cmd-e": ["workspace::ActivatePane", 0],
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "tab": "agent::CycleModeSelector",
    },
  },
  {
    "context": "AgentPanel > Editor",
    "bindings": {
      "tab": "agent::CycleModeSelector",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-r": "editor::FindAllReferences",
      "cmd-g": "editor::GoToDefinition",
      "cmd-o": "outline::Toggle",
      "cmd-;": "go_to_line::Toggle",
    },
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-shift-g": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-j": "terminal_panel::ToggleFocus",
      "cmd-j cmd-j": "terminal_panel::Toggle",
      "cmd-j cmd-n": "workspace::NewTerminal",
      "cmd-j cmd-1": ["pane::ActivateItem", 0],
      "cmd-j cmd-2": ["pane::ActivateItem", 1],
      "cmd-j cmd-3": ["pane::ActivateItem", 2],
      "cmd-j cmd-4": ["pane::ActivateItem", 3],
      "cmd-j cmd-5": ["pane::ActivateItem", 4],
      "cmd-j cmd-6": ["pane::ActivateItem", 5],
      "cmd-j cmd-7": ["pane::ActivateItem", 6],
      "cmd-j cmd-8": ["pane::ActivateItem", 7],
      "cmd-j cmd-9": ["pane::ActivateItem", 8],
      "cmd-j cmd-0": ["pane::ActivateItem", 9],
    },
  },
  {
    "context": "DebugPanel",
    "bindings": {
      "cmd-j": "terminal_panel::ToggleFocus",
      "cmd-shift-d": "workspace::ToggleBottomDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-i cmd-a": "agent::AddSelectionToThread",
      "cmd-i cmd-c": "agent::ToggleFocus",
      "cmd-i cmd-l": "multi_workspace::ToggleWorkspaceSidebar",
      "cmd-i cmd-i": "assistant::InlineAssist",
      "cmd-i cmd-n": "agent::NewThread",
      "cmd-i cmd-s": "agent::OpenSettings",
      "cmd-j cmd-j": "terminal_panel::Toggle",
      "cmd-k cmd-,": "zed::OpenSettings",
      "cmd-k cmd-p": "projects::OpenRecent",
      "cmd-k cmd-b": "git::Branch",
      "cmd-k cmd-n": "workspace::NewWindow",
    },
  },
]
