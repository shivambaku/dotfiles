// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "collaboration_panel": {
    "button": false,
  },
  "debugger": {
    "button": false,
    "dock": "bottom",
  },
  "agent": {
    "button": false,
    "dock": "right",
    "sidebar_side": "right",
  },
  "current_line_highlight": "none",
  "cursor_blink": false,
  "diagnostics": {
    "button": false,
    "inline": {
      "enabled": true,
    },
  },
  "experimental.theme_overrides": {
    "editor.background": "#0a0c10",
    "editor.gutter.background": "#0a0c10",
    "element.active": "#0b0b0b",
    "panel.background": "#0a0c10",
    "status_bar.background": "#0a0c10",
    "title_bar.background": "#0a0c10",
  },
  "git": {
    "git_gutter": "hide",
  },
  "git_panel": {
    "button": false,
    "dock": "left",
  },
  "global_lsp_settings": {
    "button": true,
  },
  "gutter": {
    "folds": false,
    "line_numbers": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "max_tabs": 1,
  "outline_panel": {
    "button": false,
  },
  "project_panel": {
    "button": false,
    "dock": "left",
    "git_status": false,
    "show_diagnostics": "off",
  },
  "scrollbar": {
    "diagnostics": "none",
    "git_diff": false,
  },
  "search": {
    "button": false,
  },
  "tab_bar": {
    "show": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "dock": "bottom",
  },
  "theme": "Catppuccin Mocha",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "use_system_window_tabs": true,
  "vim_mode": true,
}
